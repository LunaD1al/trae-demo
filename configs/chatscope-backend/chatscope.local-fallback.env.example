# ChatScope backend local fallback profile: all middleware runs on this machine.
# This file only contains development defaults and placeholders, not production secrets.

SPRING_PROFILES_ACTIVE=local-fallback

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:15432/chatscope
SPRING_DATASOURCE_USERNAME=chatscope
SPRING_DATASOURCE_PASSWORD=chatscope_dev_only

SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=16379
SPRING_DATA_REDIS_PASSWORD=chatscope_dev_only

SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092

CHATSCOPE_DEMO_GROUP_ID=chatscope_demo_group
CHATSCOPE_BOT_OPENIM_USER_ID=chatscope_bot
CHATSCOPE_OPENIM_API_BASE_URL=http://127.0.0.1:10002
CHATSCOPE_OPENIM_CHAT_API_BASE_URL=http://127.0.0.1:10008
CHATSCOPE_OPENIM_ADMIN_API_BASE_URL=http://127.0.0.1:10009
CHATSCOPE_OPENIM_ALLOW_PUBLIC_DIRECT_ACCESS=false

DEEPSEEK_API_KEY=<secret-from-password-manager>
CHATSCOPE_ADMIN_TOKEN=<secret-from-password-manager>
