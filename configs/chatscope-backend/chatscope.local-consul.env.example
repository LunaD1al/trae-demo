# ChatScope backend local profile: reuse Consul-registered PostgreSQL/Kafka/Redis.
# Copy to an untracked local env file before use. Do not commit real passwords or tokens.

SPRING_PROFILES_ACTIVE=local-consul

CHATSCOPE_CONSUL_URL=http://100.89.110.91:8500

SPRING_DATASOURCE_URL=jdbc:postgresql://100.89.110.91:5432/chatscope
SPRING_DATASOURCE_USERNAME=chatscope_app
SPRING_DATASOURCE_PASSWORD=<secret-from-password-manager>

# From Consul service cache-redis, not the local fallback Docker Redis.
SPRING_DATA_REDIS_HOST=100.105.213.32
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=<secret-from-password-manager>

SPRING_KAFKA_BOOTSTRAP_SERVERS=100.89.110.91:9092

CHATSCOPE_DEMO_GROUP_ID=chatscope_demo_group
CHATSCOPE_BOT_OPENIM_USER_ID=chatscope_bot
CHATSCOPE_OPENIM_API_BASE_URL=http://127.0.0.1:10002
CHATSCOPE_OPENIM_CHAT_API_BASE_URL=http://127.0.0.1:10008
CHATSCOPE_OPENIM_ADMIN_API_BASE_URL=http://127.0.0.1:10009
CHATSCOPE_OPENIM_ALLOW_PUBLIC_DIRECT_ACCESS=false

DEEPSEEK_API_KEY=<secret-from-password-manager>
CHATSCOPE_ADMIN_TOKEN=<secret-from-password-manager>
